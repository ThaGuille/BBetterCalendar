<?xml version="1.0" encoding="utf-8"?>
<!--
  Stroke-style calendar icon with subtle date dot.
  24x24 viewport, 1.6 stroke, rounded caps + joins.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Outer rounded rect (calendar body) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1F2A2A"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M5,6 L19,6 L19,20 L5,20 Z" />
    <!-- Header strip -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1F2A2A"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M5,10 L19,10" />
    <!-- Ring tabs -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1F2A2A"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:pathData="M9,4 L9,7 M15,4 L15,7" />
    <!-- Date dot -->
    <path
        android:fillColor="#1F2A2A"
        android:pathData="M12,15 m -1.4,0 a 1.4,1.4 0 1,0 2.8,0 a 1.4,1.4 0 1,0 -2.8,0" />
</vector>
