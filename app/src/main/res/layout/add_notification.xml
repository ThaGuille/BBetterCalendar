<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/event_notifications_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingBottom="@dimen/spacing_sm">

    <!-- Indent column: aligns the chip with the primary row's value column. -->
    <Space
        android:layout_width="36dp"
        android:layout_height="1dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_notification_chip"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingEnd="@dimen/spacing_xs"
        android:paddingBottom="@dimen/spacing_xs">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_notifications_empty_24"
            app:tint="@color/bb_primary" />

        <TextView
            android:id="@+id/event_notification_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xs"
            android:hint="@string/create_entry_notification_hint"
            android:textAppearance="@style/TextAppearance.BBetter.Label"
            android:textColor="@color/bb_on_surface" />

        <ImageView
            android:id="@+id/event_notification_close"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="@dimen/spacing_xs"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/create_entry_btn_close"
            android:padding="3dp"
            android:src="@drawable/ic_close_24"
            app:tint="@color/bb_on_surface_muted" />
    </LinearLayout>

</LinearLayout>
