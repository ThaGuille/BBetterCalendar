<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.calendar.CalendarFragment">

    <!-- Reservar un pequeño espacio arriba, de 70 pixels, donde escribir las
     iniciales de los días de la semana. Cada letra está a la misma distancia
     de la siguiente y ocupan el ancho de la pantalla -->
    <TextView
        android:id="@+id/calendarDayInitials"
        android:layout_width="match_parent"
        android:layout_height="25dp"
        android:layout_alignParentTop="true"
        android:layout_marginStart="1dp"
        android:layout_marginEnd="1dp"
        android:background="@color/white"
        android:gravity="center"
        android:text="L   M   X   J   V   S   D"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="visible" />


    <!-- Horizontal lines -->
    <View
        android:id="@+id/calendarHorizontalLine0"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black"
        android:visibility="visible" />
    <View
        android:id="@+id/calendarHorizontalLine1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black"
        android:visibility="visible" />
    <View
        android:id="@+id/calendarHorizontalLine2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black"
        android:visibility="visible" />
    <View
        android:id="@+id/calendarHorizontalLine3"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black"
        android:visibility="visible" />
    <View
        android:id="@+id/calendarHorizontalLine4"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black"
        android:visibility="visible" />
    <View
        android:id="@+id/calendarHorizontalLine5"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black"
        android:visibility="visible" />

    <!-- Vertical lines -->
    <View
        android:id="@+id/calendarVerticalLine0"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_below="@id/calendarDayInitials"
        android:layout_alignParentBottom="true"
        android:background="@color/black"
        android:visibility="visible" />
    <View
        android:id="@+id/calendarVerticalLine1"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="visible" />
    <View
        android:id="@+id/calendarVerticalLine2"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="visible" />
    <View
        android:id="@+id/calendarVerticalLine3"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="visible" />
    <View
        android:id="@+id/calendarVerticalLine4"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="visible" />
    <View
        android:id="@+id/calendarVerticalLine5"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="visible" />


    <TextView
        android:id="@+id/text_notifications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:textAlignment="center"
        android:textSize="20sp" />
    <ImageButton
        android:id="@+id/calendarAddEventButton"
        android:background="@drawable/rounded_square"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="65dp"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:backgroundTint="@color/white"
        android:src="@drawable/ic_add_24"
        android:elevation="5dp"
        android:focusable="true"
        android:clickable="true"
        />
</RelativeLayout>