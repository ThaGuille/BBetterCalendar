<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/calendarMonthRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bb_surface"
    tools:context=".ui.calendar.CalendarFragmentMonth">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header bar: prev arrow | month-year | next arrow -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <ImageButton
                android:id="@+id/monthPrevButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/month_view_prev"
                android:src="@drawable/ic_arrow_back_24" />

            <TextView
                android:id="@+id/monthTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.BBetter.Title"
                tools:text="June 2026" />

            <ImageButton
                android:id="@+id/monthNextButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/month_view_next"
                android:scaleX="-1"
                android:src="@drawable/ic_arrow_back_24" />
        </LinearLayout>

        <include layout="@layout/view_calendar_header" />

        <com.kizitonwose.calendar.view.CalendarView
            android:id="@+id/monthCalendarView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            app:cv_dayViewResource="@layout/cell_month_day"
            app:cv_daySize="square"
            app:cv_orientation="horizontal"
            app:cv_outDateStyle="endOfGrid"
            app:cv_scrollPaged="true" />

        <!-- Day-detail panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/dayDetailTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/TextAppearance.BBetter.Title"
                    android:textSize="14sp"
                    tools:text="Events for Jun 15, 2026" />

                <Button
                    android:id="@+id/dayDetailAddButton"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_for_this_day"
                    android:textColor="@color/bb_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/dayDetailRecycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="8dp" />
        </LinearLayout>

    </LinearLayout>

    <ImageButton
        android:id="@+id/calendarAddEventButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/rounded_square"
        android:backgroundTint="@color/bb_primary"
        android:clickable="true"
        android:elevation="5dp"
        android:focusable="true"
        android:src="@drawable/ic_add_24"
        app:tint="@color/bb_on_primary" />

</FrameLayout>
