<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/calendarWeekRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:paddingBottom="64dp"
    tools:context=".ui.calendar.CalendarFragmentWeek">

    <com.example.bbettercalendar.ui.calendar.weekview.WeekView
        android:id="@+id/weekView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:hourHeight="72dp"
        app:minHourHeight="48dp"
        app:maxHourHeight="120dp"
        app:numberOfVisibleDays="7"
        app:showCurrentTimeFirst="true"
        app:showFirstDayOfWeekFirst="true" />

    <ImageButton
        android:id="@+id/calendarAddEventButton2"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="65dp"
        android:background="@drawable/rounded_square"
        android:backgroundTint="@color/white"
        android:clickable="true"
        android:elevation="5dp"
        android:focusable="true"
        android:src="@drawable/ic_add_24" />

</FrameLayout>
