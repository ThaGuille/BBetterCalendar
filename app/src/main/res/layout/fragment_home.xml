<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPrimary"
    tools:context=".ui.home.HomeFragment">

    <TextView
        android:id="@+id/text_home"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:textAlignment="center"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/homeTimerText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="90dp"
        android:layout_marginEnd="8dp"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="20sp" />

    <ImageButton
        android:id="@+id/homePlayButton"
        android:layout_width="128dp"
        android:layout_height="128dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="128dp"
        android:background="@drawable/round_background"
        android:backgroundTint="@color/transparent"
        android:clickable="true"
        android:elevation="5dp"
        android:focusable="true"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_play_circle_filled_24"
        app:tint="?attr/colorAccent" />

    <TextView
        android:id="@+id/homeTimerTypeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/homePlayButton"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="8dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp"
        android:hint="-- Concentration --"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textColorHint="?attr/colorAccent"
        android:textSize="20sp" />

    <ImageView
        android:id="@+id/homeStreakImage"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_centerInParent="true"
        android:src="@drawable/a_streak_logo" />

    <TextView
        android:id="@+id/homeToadyFailsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="140dp"
        android:hint="Today failed attempts: 0"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textColorHint="@color/magenta"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/homeCurrentStreakText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/homeToadyFailsText"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="30dp"
        android:hint="Current Streak: 0 days"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textColorHint="@color/black"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/homeTodayTimeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/homeCurrentStreakText"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="30dp"
        android:hint="Today studied time: 00:00"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textColorHint="@color/black"
        android:textSize="20sp" />

    <ImageButton
        android:id="@+id/homeTimerButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="45dp"
        android:background="@drawable/rounded_square"
        android:backgroundTint="@color/white"
        android:clickable="true"
        android:elevation="5dp"
        android:focusable="true"
        android:src="@drawable/ic_timer_empty_24" />

</RelativeLayout>