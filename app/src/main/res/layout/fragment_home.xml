<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bb_surface"
    android:fillViewport="true"
    android:scrollbars="none"
    tools:context=".ui.home.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- ============ Header strip ============ -->
        <TextView
            android:id="@+id/text_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.BBetter.Headline"
            android:textColor="@color/bb_primary_dark"
            tools:text="Hi there" />

        <TextView
            android:id="@+id/homeDateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/TextAppearance.BBetter.Label"
            tools:text="Tuesday, May 18" />

        <!-- ============ Timer card (compactado — spec tasks-home-today) ============ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_card"
            android:padding="@dimen/home_card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <!-- Mode chip -->
                <TextView
                    android:id="@+id/homeTimerTypeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_energy"
                    android:gravity="center"
                    android:hint="@string/home_mode_concentration"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.BBetter.Chip"
                    android:textColor="@color/bb_on_primary"
                    android:textColorHint="@color/bb_on_primary" />

                <!-- Countdown -->
                <TextView
                    android:id="@+id/homeTimerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:textAppearance="@style/TextAppearance.BBetter.Display"
                    android:textColor="@color/bb_on_surface"
                    android:textSize="@dimen/text_display_compact"
                    tools:text="25:00" />

                <!-- Play / pause button -->
                <ImageButton
                    android:id="@+id/homePlayButton"
                    android:layout_width="@dimen/home_play_button_size"
                    android:layout_height="@dimen/home_play_button_size"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_play_button"
                    android:clickable="true"
                    android:contentDescription="@string/home_play"
                    android:elevation="@dimen/elevation_floating"
                    android:focusable="true"
                    android:padding="16dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_play_v2_filled_24" />

                <!-- Focus block-mode toggle: arms/disarms blocking every other app while the
                     concentration timer runs (see blocking/FocusBlockState.java). Editable only
                     while stopped/paused; disabled mid-run (disarming would instantly unblock). -->
                <TextView
                    android:id="@+id/homeBlockModeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_block_mode_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="@string/home_block_mode"
                    android:textAppearance="@style/TextAppearance.BBetter.Chip"
                    android:textColor="@color/bb_on_primary" />

                <!-- Skip-rest button (only shown while resting) -->
                <TextView
                    android:id="@+id/homeSkipRestButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:background="@drawable/bg_chip_secondary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="@string/home_skip_rest"
                    android:textAppearance="@style/TextAppearance.BBetter.Chip"
                    android:textColor="@color/bb_on_primary"
                    android:visibility="gone" />

            </LinearLayout>
        </FrameLayout>

        <!-- ============ Stats row (antes "Today" en 3 filas — compactado a 1 fila,
             spec tasks-home-today) ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_card"
            android:orientation="horizontal"
            android:paddingStart="@dimen/spacing_md"
            android:paddingEnd="@dimen/spacing_md"
            android:paddingTop="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_md">

            <!-- Studied today -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="@dimen/home_stat_icon_size"
                    android:layout_height="@dimen/home_stat_icon_size"
                    android:contentDescription="@string/home_stat_studied_label"
                    android:src="@drawable/ic_clock_v2_24"
                    app:tint="@color/bb_primary" />

                <TextView
                    android:id="@+id/homeTodayTimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:hint="@string/home_stat_studied_placeholder"
                    android:textAppearance="@style/TextAppearance.BBetter.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/home_stat_studied_label"
                    android:textAppearance="@style/TextAppearance.BBetter.Label" />
            </LinearLayout>

            <!-- Streak -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/homeStreakImage"
                    android:layout_width="@dimen/home_stat_icon_size"
                    android:layout_height="@dimen/home_stat_icon_size"
                    android:contentDescription="@string/home_stat_streak_label"
                    android:src="@drawable/ic_flame_v2_24"
                    app:tint="@color/bb_accent_reward" />

                <TextView
                    android:id="@+id/homeCurrentStreakText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:hint="@string/home_stat_streak_placeholder"
                    android:textAppearance="@style/TextAppearance.BBetter.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/home_stat_streak_label"
                    android:textAppearance="@style/TextAppearance.BBetter.Label" />
            </LinearLayout>

            <!-- Missed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="@dimen/home_stat_icon_size"
                    android:layout_height="@dimen/home_stat_icon_size"
                    android:contentDescription="@string/home_stat_fails_label"
                    android:src="@drawable/ic_cross_v2_24"
                    app:tint="@color/bb_danger" />

                <TextView
                    android:id="@+id/homeToadyFailsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:hint="@string/home_stat_fails_placeholder"
                    android:textAppearance="@style/TextAppearance.BBetter.Body"
                    android:textColor="@color/bb_danger" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/home_stat_fails_label"
                    android:textAppearance="@style/TextAppearance.BBetter.Label" />
            </LinearLayout>

        </LinearLayout>

        <!-- ============ Today tasks card (spec tasks-home-today) ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_card"
            android:orientation="vertical"
            android:padding="@dimen/home_card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_tasks_card_title"
                    android:textAppearance="@style/TextAppearance.BBetter.Title" />

                <ImageButton
                    android:id="@+id/homeAddTaskButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/home_tasks_add"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_add_24"
                    app:tint="@color/bb_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/homeTasksEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/home_tasks_empty"
                android:textAppearance="@style/TextAppearance.BBetter.BodyMuted"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/homeTodayTaskList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/homeShowOverdueButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingBottom="@dimen/spacing_xs"
                android:text="@string/home_tasks_show_overdue"
                android:textAppearance="@style/TextAppearance.BBetter.Label"
                android:textColor="@color/bb_primary" />

            <LinearLayout
                android:id="@+id/homeOverdueSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/homeOverdueEmptyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/home_tasks_overdue_empty"
                    android:textAppearance="@style/TextAppearance.BBetter.BodyMuted"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/homeOverdueTaskList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
