<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bb_surface"
    android:fillViewport="true"
    android:scrollbars="none"
    tools:context=".ui.home.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- ============ Header strip ============ -->
        <TextView
            android:id="@+id/text_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.BBetter.Headline"
            android:textColor="@color/bb_primary_dark"
            tools:text="Hi there" />

        <TextView
            android:id="@+id/homeDateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/TextAppearance.BBetter.Label"
            tools:text="Tuesday, May 18" />

        <!-- ============ Timer card ============ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_card"
            android:padding="@dimen/home_card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <!-- Mode chip -->
                <TextView
                    android:id="@+id/homeTimerTypeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_energy"
                    android:gravity="center"
                    android:hint="@string/home_mode_concentration"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.BBetter.Chip"
                    android:textColor="@color/bb_on_primary"
                    android:textColorHint="@color/bb_on_primary" />

                <!-- Countdown -->
                <TextView
                    android:id="@+id/homeTimerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:textAppearance="@style/TextAppearance.BBetter.Display"
                    android:textColor="@color/bb_on_surface"
                    tools:text="25:00" />

                <!-- Play / pause button -->
                <ImageButton
                    android:id="@+id/homePlayButton"
                    android:layout_width="@dimen/home_play_button_size"
                    android:layout_height="@dimen/home_play_button_size"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:background="@drawable/bg_play_button"
                    android:clickable="true"
                    android:contentDescription="@string/home_play"
                    android:elevation="@dimen/elevation_floating"
                    android:focusable="true"
                    android:padding="20dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_play_v2_filled_24" />

                <!-- Skip-rest button (only shown while resting) -->
                <TextView
                    android:id="@+id/homeSkipRestButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:background="@drawable/bg_chip_secondary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:text="@string/home_skip_rest"
                    android:textAppearance="@style/TextAppearance.BBetter.Chip"
                    android:textColor="@color/bb_on_primary"
                    android:visibility="gone" />

            </LinearLayout>
        </FrameLayout>

        <!-- ============ Today card ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_card"
            android:orientation="vertical"
            android:padding="@dimen/home_card_padding">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_today_card_title"
                android:textAppearance="@style/TextAppearance.BBetter.Title" />

            <!-- Studied today -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/home_stat_icon_size"
                    android:layout_height="@dimen/home_stat_icon_size"
                    android:contentDescription="@string/home_stat_studied_label"
                    android:src="@drawable/ic_clock_v2_24"
                    app:tint="@color/bb_primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_stat_studied_label"
                        android:textAppearance="@style/TextAppearance.BBetter.Label" />

                    <TextView
                        android:id="@+id/homeTodayTimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:hint="@string/home_stat_studied_placeholder"
                        android:textAppearance="@style/TextAppearance.BBetter.Body" />
                </LinearLayout>
            </LinearLayout>

            <!-- Streak -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/homeStreakImage"
                    android:layout_width="@dimen/home_stat_icon_size"
                    android:layout_height="@dimen/home_stat_icon_size"
                    android:contentDescription="@string/home_stat_streak_label"
                    android:src="@drawable/ic_flame_v2_24"
                    app:tint="@color/bb_accent_reward" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_stat_streak_label"
                        android:textAppearance="@style/TextAppearance.BBetter.Label" />

                    <TextView
                        android:id="@+id/homeCurrentStreakText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:hint="@string/home_stat_streak_placeholder"
                        android:textAppearance="@style/TextAppearance.BBetter.Body" />
                </LinearLayout>
            </LinearLayout>

            <!-- Missed -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/home_stat_icon_size"
                    android:layout_height="@dimen/home_stat_icon_size"
                    android:contentDescription="@string/home_stat_fails_label"
                    android:src="@drawable/ic_cross_v2_24"
                    app:tint="@color/bb_danger" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_stat_fails_label"
                        android:textAppearance="@style/TextAppearance.BBetter.Label" />

                    <TextView
                        android:id="@+id/homeToadyFailsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:hint="@string/home_stat_fails_placeholder"
                        android:textAppearance="@style/TextAppearance.BBetter.Body"
                        android:textColor="@color/bb_danger" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
