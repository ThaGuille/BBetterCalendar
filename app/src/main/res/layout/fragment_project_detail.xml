<?xml version="1.0" encoding="utf-8"?>
<!-- Detalle de proyecto (spec projects-mvp): header editable (nombre/notas/deadline), lista de
     items y acciones de completar/borrar. Mismo patrón de scroll que fragment_home.xml. -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bb_surface"
    android:fillViewport="true"
    android:scrollbars="none"
    tools:context=".ui.projects.ProjectDetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_lg">

        <!-- ============ Header card: name / notes / deadline ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_card"
            android:orientation="vertical"
            android:padding="@dimen/home_card_padding">

            <EditText
                android:id="@+id/projectDetailNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="@string/create_project_name_hint"
                android:importantForAutofill="no"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.BBetter.Title" />

            <EditText
                android:id="@+id/projectDetailNotesInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:background="@null"
                android:gravity="top"
                android:hint="@string/create_project_notes_hint"
                android:importantForAutofill="no"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2"
                android:maxLines="6"
                android:textAppearance="@style/TextAppearance.BBetter.BodyMuted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/projectDetailDeadlineButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingTop="@dimen/spacing_xs"
                    android:paddingBottom="@dimen/spacing_xs"
                    android:text="@string/create_project_set_deadline"
                    android:textAppearance="@style/TextAppearance.BBetter.Label"
                    android:textColor="@color/bb_primary" />

                <TextView
                    android:id="@+id/projectDetailDeadlineChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_secondary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textAppearance="@style/TextAppearance.BBetter.Chip"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/projectDetailSaveHeaderButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="@drawable/bg_chip_energy"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="@string/project_detail_save"
                android:textAppearance="@style/TextAppearance.BBetter.Chip"
                android:textColor="@color/bb_on_primary" />

        </LinearLayout>

        <!-- ============ Items card ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_card"
            android:elevation="@dimen/elevation_card"
            android:orientation="vertical"
            android:padding="@dimen/home_card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/project_detail_items_title"
                    android:textAppearance="@style/TextAppearance.BBetter.Title" />

                <ImageButton
                    android:id="@+id/projectDetailAddItemButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/project_detail_add_item"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_add_24"
                    app:tint="@color/bb_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/projectDetailItemsEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/project_detail_items_empty"
                android:textAppearance="@style/TextAppearance.BBetter.BodyMuted"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/projectDetailItemsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

        </LinearLayout>

        <!-- ============ Actions ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/projectDetailCompleteButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_chip_energy"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/project_detail_complete"
                android:textAppearance="@style/TextAppearance.BBetter.Chip"
                android:textColor="@color/bb_on_primary" />

            <TextView
                android:id="@+id/projectDetailDeleteButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="@dimen/spacing_sm"
                android:text="@string/project_detail_delete"
                android:textAppearance="@style/TextAppearance.BBetter.Label"
                android:textColor="@color/bb_danger" />

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
