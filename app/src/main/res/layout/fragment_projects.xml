<?xml version="1.0" encoding="utf-8"?>
<!-- Lista de proyectos (spec projects-mvp): reemplaza el stub copy-paste. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bb_surface"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_md"
    tools:context=".ui.projects.ProjectsFragment">

    <TextView
        android:id="@+id/projectsHeaderText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_projects"
        android:textAppearance="@style/TextAppearance.BBetter.Headline"
        app:layout_constraintEnd_toStartOf="@id/projectsAddButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/projectsAddButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/projects_add"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_add_24"
        app:layout_constraintBottom_toBottomOf="@id/projectsHeaderText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/projectsHeaderText"
        app:tint="@color/bb_primary" />

    <TextView
        android:id="@+id/projectsEmptyText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="@string/projects_empty"
        android:textAppearance="@style/TextAppearance.BBetter.BodyMuted"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/projectsHeaderText" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/projectsList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_sm"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/projectsHeaderText" />

</androidx.constraintlayout.widget.ConstraintLayout>
