<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md">

    <!-- Toggle "hacer cumplir el límite" (Phase 4a): estado (tint/alpha) y click los pone el adapter.
         padding + minWidth/Height amplían el área táctil sin agrandar el icono. -->
    <ImageView
        android:id="@+id/usage_block_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="@string/progress_usage_block_toggle"
        android:focusable="true"
        android:minWidth="40dp"
        android:minHeight="40dp"
        android:padding="@dimen/spacing_sm"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_block_24" />

    <ImageView
        android:id="@+id/usage_app_icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="@dimen/spacing_md"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/usage_app_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="@style/TextAppearance.BBetter.Body" />

    <TextView
        android:id="@+id/usage_app_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.BBetter.Title" />

</LinearLayout>
