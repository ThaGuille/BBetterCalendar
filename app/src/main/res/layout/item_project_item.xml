<?xml version="1.0" encoding="utf-8"?>
<!-- Fila de un item (CalendarEntry type task) dentro del detalle de proyecto (spec projects-mvp).
     Igual que item_today_task.xml pero sin el botón "quitar" (no aplica a items de proyecto) y
     con una etiqueta "sin fecha" para los items que viven sólo dentro del proyecto. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="@dimen/spacing_xs"
    android:paddingBottom="@dimen/spacing_xs">

    <CheckBox
        android:id="@+id/projectItemDoneCheckbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/bb_primary"
        android:minWidth="0dp"
        android:minHeight="0dp" />

    <TextView
        android:id="@+id/projectItemTitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="2"
        android:textAppearance="@style/TextAppearance.BBetter.Body"
        android:textColor="@color/bb_on_surface" />

    <TextView
        android:id="@+id/projectItemDateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.BBetter.Label" />

</LinearLayout>
