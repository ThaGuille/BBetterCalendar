<?xml version="1.0" encoding="utf-8"?>
<!-- Fila de un item (CalendarEntry type task) dentro del detalle de proyecto (spec projects-mvp).
     Igual que item_today_task.xml pero sin el botón "quitar" (no aplica a items de proyecto) y
     con una etiqueta "sin fecha" para los items que viven sólo dentro del proyecto. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="@dimen/spacing_xs"
    android:paddingBottom="@dimen/spacing_xs">

    <CheckBox
        android:id="@+id/projectItemDoneCheckbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/bb_primary"
        android:minWidth="0dp"
        android:minHeight="0dp" />

    <TextView
        android:id="@+id/projectItemTitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="2"
        android:textAppearance="@style/TextAppearance.BBetter.Body"
        android:textColor="@color/bb_on_surface" />

    <!-- Progreso de minutos atribuidos "X/Ym" (spec focus-attribution). Sólo visible para items
         con objetivo; lo rellena ProjectItemAdapter desde CalendarEntry.attributedMinutes. -->
    <TextView
        android:id="@+id/projectItemProgressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.BBetter.Label"
        android:textColor="@color/bb_primary"
        android:visibility="gone" />

    <TextView
        android:id="@+id/projectItemDateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.BBetter.Label" />

    <!-- "Focus this" (spec focus-attribution): vincula el timer de Home a este item, navega a Home
         y arranca la sesión. Sólo visible para items con objetivo no completados. -->
    <TextView
        android:id="@+id/projectItemFocusButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="@string/task_focus_this_desc"
        android:focusable="true"
        android:padding="@dimen/spacing_xs"
        android:text="@string/task_focus_this_symbol"
        android:textAppearance="@style/TextAppearance.BBetter.Label"
        android:textColor="@color/bb_primary"
        android:visibility="gone" />

</LinearLayout>
