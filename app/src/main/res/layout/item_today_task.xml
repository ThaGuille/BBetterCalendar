<?xml version="1.0" encoding="utf-8"?>
<!-- Fila de la lista de tareas de hoy en Home (spec tasks-home-today).
     Checkbox + título + hora/fecha; el tachado de tareas hechas lo aplica TodayTaskAdapter. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="@dimen/spacing_xs"
    android:paddingBottom="@dimen/spacing_xs">

    <CheckBox
        android:id="@+id/taskDoneCheckbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/bb_primary"
        android:minWidth="0dp"
        android:minHeight="0dp" />

    <TextView
        android:id="@+id/taskTitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="2"
        android:textAppearance="@style/TextAppearance.BBetter.Body"
        android:textColor="@color/bb_on_surface" />

    <!-- Progreso de minutos atribuidos "X/Ym" (spec focus-attribution). Sólo visible para tareas
         con objetivo; lo rellena TodayTaskAdapter desde CalendarEntry.attributedMinutes. -->
    <TextView
        android:id="@+id/taskProgressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.BBetter.Label"
        android:textColor="@color/bb_primary"
        android:visibility="gone" />

    <TextView
        android:id="@+id/taskTimeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:textAppearance="@style/TextAppearance.BBetter.Label" />

    <!-- "Focus this" (spec focus-attribution): vincula el timer de Home a esta tarea y arranca la
         sesión. Sólo visible para tareas con objetivo no completadas. -->
    <TextView
        android:id="@+id/taskFocusButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="@string/task_focus_this_desc"
        android:focusable="true"
        android:padding="@dimen/spacing_xs"
        android:text="@string/task_focus_this_symbol"
        android:textAppearance="@style/TextAppearance.BBetter.Label"
        android:textColor="@color/bb_primary"
        android:visibility="gone" />

    <!-- "Quitar" de una tarea atrasada (spec tasks-recurrence): oculto salvo en la sección de
         atrasadas, donde TodayTaskAdapter recibe un OnTaskRemoveListener. No borra: retira. -->
    <TextView
        android:id="@+id/taskRemoveButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:contentDescription="@string/home_overdue_remove_desc"
        android:focusable="true"
        android:padding="@dimen/spacing_xs"
        android:text="@string/home_overdue_remove_symbol"
        android:textAppearance="@style/TextAppearance.BBetter.Label"
        android:textColor="@color/bb_on_surface_muted"
        android:visibility="gone" />

</LinearLayout>
