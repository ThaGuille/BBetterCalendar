<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/spacing_md">

    <TextView
        android:id="@+id/popup_description_label"
        android:layout_width="0dp"
        android:layout_height="@dimen/form_row_inner_height"
        android:layout_marginStart="@dimen/spacing_md"
        android:gravity="center|start"
        android:hint="Description"
        android:textColorHint="@color/black"
        android:textSize="@dimen/text_body"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/popup_description_edit_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:gravity="center|start"
        android:textColorHint="@color/black"
        android:textSize="@dimen/text_body"
        app:layout_constraintTop_toBottomOf="@id/popup_description_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/okButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/rounded_square"
        android:backgroundTint="@color/white"
        android:text="OK"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/popup_description_edit_text"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
