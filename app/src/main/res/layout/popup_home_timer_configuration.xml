<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_timer_clock_24"
                app:tint="@color/bb_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/timer_popup_title"
                    android:textAppearance="@style/TextAppearance.BBetter.Title" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/timer_popup_subtitle"
                    android:textAppearance="@style/TextAppearance.BBetter.BodyMuted"
                    android:textSize="@dimen/text_label" />
            </LinearLayout>
        </LinearLayout>

        <!-- Concentration tile -->
        <LinearLayout
            android:id="@+id/tile_concentration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_tile_energy"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_energy"
                android:text="@string/timer_concentration_label"
                android:textAppearance="@style/TextAppearance.BBetter.Chip" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:baselineAligned="true"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_time_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/fraunces"
                    android:letterSpacing="-0.02"
                    android:text="20:00"
                    android:textColor="@color/bb_accent_energy"
                    android:textSize="44sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:layout_marginBottom="6dp"
                    android:text="@string/timer_minutes_unit"
                    android:textAppearance="@style/TextAppearance.BBetter.BodyMuted" />
            </LinearLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_timer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:stepSize="1"
                android:valueFrom="1"
                android:valueTo="90"
                app:haloColor="@color/bb_accent_energy"
                app:thumbColor="@color/bb_accent_energy"
                app:tickVisible="false"
                app:trackColorActive="@color/bb_accent_energy"
                app:trackColorInactive="@color/bb_divider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/timer_range_min"
                    android:textAppearance="@style/TextAppearance.BBetter.Label" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/timer_range_max"
                    android:textAppearance="@style/TextAppearance.BBetter.Label" />
            </LinearLayout>
        </LinearLayout>

        <!-- Rest tile -->
        <LinearLayout
            android:id="@+id/tile_rest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_tile_primary"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_primary"
                    android:text="@string/timer_rest_label"
                    android:textAppearance="@style/TextAppearance.BBetter.Chip" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_rest_enabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/bb_surface_card"
                    app:trackTint="@color/bb_primary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rest_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="true"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/text_time_resting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/fraunces"
                        android:letterSpacing="-0.02"
                        android:text="05:00"
                        android:textColor="@color/bb_primary"
                        android:textSize="44sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_marginBottom="6dp"
                        android:text="@string/timer_minutes_unit"
                        android:textAppearance="@style/TextAppearance.BBetter.BodyMuted" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_rest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:stepSize="1"
                    android:valueFrom="1"
                    android:valueTo="20"
                    app:haloColor="@color/bb_primary"
                    app:thumbColor="@color/bb_primary"
                    app:tickVisible="false"
                    app:trackColorActive="@color/bb_primary"
                    app:trackColorInactive="@color/bb_divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/timer_range_min"
                        android:textAppearance="@style/TextAppearance.BBetter.Label" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/timer_range_rest_max"
                        android:textAppearance="@style/TextAppearance.BBetter.Label" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Cycles -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/timer_cycles_label"
                android:textAppearance="@style/TextAppearance.BBetter.Body" />

            <ImageButton
                android:id="@+id/btn_subtract_cycles"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_stepper_circle"
                android:contentDescription="@string/timer_cycles_label"
                android:scaleType="centerInside"
                android:src="@drawable/ic_substract_24"
                app:tint="@color/bb_primary" />

            <TextView
                android:id="@+id/text_cycles"
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="3"
                android:textAppearance="@style/TextAppearance.BBetter.Title" />

            <ImageButton
                android:id="@+id/btn_add_cycles"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_stepper_circle"
                android:contentDescription="@string/timer_cycles_label"
                android:scaleType="centerInside"
                android:src="@drawable/ic_add_24"
                app:tint="@color/bb_primary" />
        </LinearLayout>

        <!-- Infinite pill -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="end"
            android:orientation="horizontal">

            <ToggleButton
                android:id="@+id/toggle_infinite_cycles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_infinite_pill"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:minHeight="36dp"
                android:minWidth="0dp"
                android:paddingStart="@dimen/spacing_md"
                android:paddingEnd="@dimen/spacing_md"
                android:textAllCaps="false"
                android:textColor="@color/bb_on_surface"
                android:textOff="∞ Infinite"
                android:textOn="∞ Infinite"
                android:textSize="@dimen/text_label" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@color/bb_divider" />

        <!-- Auto-cycle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/timer_auto_cycle_label"
                    android:textAppearance="@style/TextAppearance.BBetter.Body" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/timer_auto_cycle_hint"
                    android:textAppearance="@style/TextAppearance.BBetter.Label" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_auto_cycle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/bb_surface_card"
                app:trackTint="@color/bb_primary" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@color/bb_divider" />

        <!-- Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_restore"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timer_btn_restore"
                android:textAllCaps="false"
                android:textColor="@color/bb_on_surface_muted"
                app:icon="@drawable/ic_restore_24"
                app:iconTint="@color/bb_on_surface_muted" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/bb_accent_energy"
                android:text="@string/timer_btn_save"
                android:textAllCaps="false"
                android:textColor="@color/bb_on_primary"
                app:cornerRadius="@dimen/radius_md" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
