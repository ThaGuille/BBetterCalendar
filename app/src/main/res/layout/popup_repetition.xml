<?xml version="1.0" encoding="utf-8"?>
<!-- Selector de recurrencia (spec tasks-recurrence). Las 4 filas base ya no auto-cierran el
     diálogo: al elegir "Diaria" aparece el intervalo "cada X días" y al elegir "Semanal" los
     toggles de día de la semana. El botón Hecho confirma y devuelve un RepetitionSpec. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingBottom="@dimen/spacing_md">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_xs"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:text="@string/repetition_popup_title"
        android:textAppearance="@style/TextAppearance.BBetter.Title" />

    <LinearLayout
        android:id="@+id/repetition_popup_row_none"
        style="@style/BBetter.CardFormRow">

        <TextView
            style="@style/BBetter.CardFormRow.Value"
            android:layout_marginStart="0dp"
            android:text="@string/repetition_option_none" />

        <ToggleButton
            android:id="@+id/repetition_popup_toggle_none"
            android:layout_width="@dimen/toggle_button_size"
            android:layout_height="@dimen/toggle_button_size"
            android:background="@drawable/bb_radio_indicator"
            android:button="@android:color/transparent"
            android:clickable="false"
            android:focusable="false"
            android:textOff=""
            android:textOn="" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:background="@color/bb_divider" />

    <LinearLayout
        android:id="@+id/repetition_popup_row_daily"
        style="@style/BBetter.CardFormRow">

        <TextView
            style="@style/BBetter.CardFormRow.Value"
            android:layout_marginStart="0dp"
            android:text="@string/repetition_option_daily" />

        <ToggleButton
            android:id="@+id/repetition_popup_toggle_daily"
            android:layout_width="@dimen/toggle_button_size"
            android:layout_height="@dimen/toggle_button_size"
            android:background="@drawable/bb_radio_indicator"
            android:button="@android:color/transparent"
            android:clickable="false"
            android:focusable="false"
            android:textOff=""
            android:textOn="" />
    </LinearLayout>

    <!-- Intervalo "cada X días", visible sólo con Diaria seleccionada. -->
    <LinearLayout
        android:id="@+id/repetition_popup_daily_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_sm"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/repetition_every_label"
            android:textAppearance="@style/TextAppearance.BBetter.Label"
            android:textColor="@color/bb_on_surface_muted" />

        <TextView
            android:id="@+id/repetition_interval_minus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_stepper_circle"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/repetition_stepper_minus"
            android:textAppearance="@style/TextAppearance.BBetter.Title"
            android:textColor="@color/bb_on_surface" />

        <TextView
            android:id="@+id/repetition_interval_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_md"
            android:minWidth="56dp"
            android:gravity="center"
            android:text="@string/repetition_interval_days_one"
            android:textAppearance="@style/TextAppearance.BBetter.Body"
            android:textColor="@color/bb_on_surface" />

        <TextView
            android:id="@+id/repetition_interval_plus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_stepper_circle"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/repetition_stepper_plus"
            android:textAppearance="@style/TextAppearance.BBetter.Title"
            android:textColor="@color/bb_on_surface" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:background="@color/bb_divider" />

    <LinearLayout
        android:id="@+id/repetition_popup_row_weekly"
        style="@style/BBetter.CardFormRow">

        <TextView
            style="@style/BBetter.CardFormRow.Value"
            android:layout_marginStart="0dp"
            android:text="@string/repetition_option_weekly" />

        <ToggleButton
            android:id="@+id/repetition_popup_toggle_weekly"
            android:layout_width="@dimen/toggle_button_size"
            android:layout_height="@dimen/toggle_button_size"
            android:background="@drawable/bb_radio_indicator"
            android:button="@android:color/transparent"
            android:clickable="false"
            android:focusable="false"
            android:textOff=""
            android:textOn="" />
    </LinearLayout>

    <!-- Días de la semana, visibles sólo con Semanal seleccionada. Los 7 toggles se rellenan
         y etiquetan en RepetitionPopup desde R.array.weekday_initials. -->
    <LinearLayout
        android:id="@+id/repetition_popup_weekly_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        android:visibility="gone">

        <ToggleButton
            android:id="@+id/repetition_weekday_0"
            style="@style/BBetter.WeekdayToggle" />

        <ToggleButton
            android:id="@+id/repetition_weekday_1"
            style="@style/BBetter.WeekdayToggle" />

        <ToggleButton
            android:id="@+id/repetition_weekday_2"
            style="@style/BBetter.WeekdayToggle" />

        <ToggleButton
            android:id="@+id/repetition_weekday_3"
            style="@style/BBetter.WeekdayToggle" />

        <ToggleButton
            android:id="@+id/repetition_weekday_4"
            style="@style/BBetter.WeekdayToggle" />

        <ToggleButton
            android:id="@+id/repetition_weekday_5"
            style="@style/BBetter.WeekdayToggle" />

        <ToggleButton
            android:id="@+id/repetition_weekday_6"
            style="@style/BBetter.WeekdayToggle" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:background="@color/bb_divider" />

    <LinearLayout
        android:id="@+id/repetition_popup_row_monthly"
        style="@style/BBetter.CardFormRow">

        <TextView
            style="@style/BBetter.CardFormRow.Value"
            android:layout_marginStart="0dp"
            android:text="@string/repetition_option_monthly" />

        <ToggleButton
            android:id="@+id/repetition_popup_toggle_monthly"
            android:layout_width="@dimen/toggle_button_size"
            android:layout_height="@dimen/toggle_button_size"
            android:background="@drawable/bb_radio_indicator"
            android:button="@android:color/transparent"
            android:clickable="false"
            android:focusable="false"
            android:textOff=""
            android:textOn="" />
    </LinearLayout>

    <TextView
        android:id="@+id/repetition_popup_confirm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:background="@drawable/bg_chip_energy"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="@string/repetition_popup_confirm"
        android:textAppearance="@style/TextAppearance.BBetter.Chip"
        android:textColor="@color/bb_on_primary" />

</LinearLayout>
