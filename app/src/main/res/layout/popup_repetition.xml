<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:orientation="vertical"
    android:textSize="20sp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="0dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center|start"

        android:orientation="horizontal">

        <ToggleButton
            android:id="@+id/repetition_popup_toggle_none"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/radio_button_selector"
            android:layout_marginLeft="20dp"
            android:textOn=""
            android:textOff=""
            android:button="@android:color/transparent"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="0dp"
            android:gravity="center|start"
            android:hint="No se repite"
            android:layout_marginLeft="20dp"
            android:textColorHint="@color/black"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="0dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center|start"

        android:orientation="horizontal">

        <ToggleButton
            android:id="@+id/repetition_popup_toggle_daily"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/radio_button_selector"
            android:layout_marginLeft="20dp"
            android:textOn=""
            android:textOff=""
            android:button="@android:color/transparent"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="0dp"
            android:gravity="center|start"
            android:hint="Todos los días"
            android:layout_marginLeft="20dp"
            android:textColorHint="@color/black"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="0dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center|start"

        android:orientation="horizontal">

        <ToggleButton
            android:id="@+id/repetition_popup_toggle_weekly"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/radio_button_selector"
            android:layout_marginLeft="20dp"
            android:textOn=""
            android:textOff=""
            android:button="@android:color/transparent"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="0dp"
            android:gravity="center|start"
            android:hint="Todas las semanas"
            android:layout_marginLeft="20dp"
            android:textColorHint="@color/black"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="0dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center|start"

        android:orientation="horizontal">

        <ToggleButton
            android:id="@+id/repetition_popup_toggle_monthly"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/radio_button_selector"
            android:layout_marginLeft="20dp"
            android:textOn=""
            android:textOff=""
            android:button="@android:color/transparent"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="0dp"
            android:gravity="center|start"
            android:hint="Todos los meses"
            android:layout_marginLeft="20dp"
            android:textColorHint="@color/black"
            android:textSize="20sp" />
    </LinearLayout>

</LinearLayout>