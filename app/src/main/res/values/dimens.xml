<resources>
    <!-- Default screen margins, per the Android Design guidelines. -->
    <dimen name="activity_horizontal_margin">16dp</dimen>
    <dimen name="activity_vertical_margin">16dp</dimen>
    <dimen name="cuarenta_y_ocho">56dp</dimen>

    <!-- Spacing scale -->
    <dimen name="spacing_xs">4dp</dimen>
    <dimen name="spacing_sm">8dp</dimen>
    <dimen name="spacing_md">16dp</dimen>
    <dimen name="spacing_lg">25dp</dimen>
    <dimen name="spacing_xl">36dp</dimen>

    <!-- Form rows -->
    <dimen name="form_row_height">70dp</dimen>
    <dimen name="form_row_icon_size">45dp</dimen>
    <dimen name="form_row_arrow_size">20dp</dimen>
    <dimen name="form_row_inner_height">45dp</dimen>

    <!-- Buttons -->
    <dimen name="icon_button_size">56dp</dimen>
    <dimen name="primary_button_size">128dp</dimen>
    <dimen name="segmented_button_height">36dp</dimen>
    <dimen name="toggle_button_size">30dp</dimen>

    <!-- Text scale -->
    <dimen name="text_display">56sp</dimen>
    <dimen name="text_headline">24sp</dimen>
    <dimen name="text_title">18sp</dimen>
    <dimen name="text_body">16sp</dimen>
    <dimen name="text_label">13sp</dimen>
    <dimen name="text_small">12sp</dimen>
    <dimen name="text_dialog">18sp</dimen>

    <!-- Corner radii -->
    <dimen name="radius_sm">8dp</dimen>
    <dimen name="radius_md">14dp</dimen>
    <dimen name="radius_lg">24dp</dimen>

    <!-- Elevations -->
    <dimen name="elevation_card">2dp</dimen>
    <dimen name="elevation_floating">8dp</dimen>

    <!-- Home screen -->
    <dimen name="home_card_padding">20dp</dimen>
    <dimen name="home_play_button_size">88dp</dimen>
    <dimen name="home_stat_icon_size">28dp</dimen>

    <!-- Fixed positions formerly hardcoded -->
    <dimen name="home_timer_button_margin_bottom">45dp</dimen>
    <dimen name="calendar_fab_margin_bottom">65dp</dimen>

    <!-- Dialog widths -->
    <dimen name="dialog_min_width">240dp</dimen>

    <!-- Progress screen -->
    <!-- Carrusel algo más bajo (era 300dp) para dejar sitio a la banda de uso de Phase 2; la
         pantalla scrollea entera, así que en pantallas pequeñas no se recorta nada. -->
    <dimen name="progress_chart_height">240dp</dimen>
    <!-- Altura mínima del área de la banda de uso (tarjeta LOCKED/EMPTY o lista) para que no quede
         aplastada cuando hay pocas apps. -->
    <dimen name="progress_usage_band_min_height">180dp</dimen>
</resources>
