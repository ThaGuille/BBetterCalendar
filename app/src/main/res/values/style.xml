   <style name="CalendarLegendDay">
       <item name="android:layout_width">0dp</item>
       <item name="android:layout_height">wrap_content</item>
       <item name="android:layout_weight">1</item>
       <item name="android:gravity">center</item>
       <item name="android:textColor">@color/black</item>
       <item name="android:textSize">12sp</item>
       <item name="android:textStyle">bold</item>
   </style>

   <style name="AppTheme.WeekDays" parent="Theme.MaterialComponents.Light.NoActionBar" >
       <item name="android:textColor">@color/black</item>
       <item name="android:textSize">15sp</item>
       <item name="android:textStyle">bold</item>
       <item name="android:background">@color/white</item>
       <item name="android:gravity">center</item>
       <item name="android:layout_weight">1</item>
       <item name="android:layout_alignParentTop">true</item>
       <item name="android:layout_marginEnd">1dp</item>

       <item name="android:layout_width">0dp</item>
       <item name="android:layout_height">25dp</item>
   </style>

   <style name="AppTheme.CalendarHours" parent="Theme.MaterialComponents.Light.NoActionBar" >
       <item name="android:textColor">@color/black</item>
       <item name="android:textSize">10sp</item>
       <item name="android:textStyle">bold</item>
       <item name="android:background">@color/white</item>
       <item name="android:gravity">center</item>
       <item name="android:layout_height">70dp</item>
       <item name="android:layout_alignParentTop">true</item>
   </style>

    <style name="RoundedDialog" parent="Theme.MaterialComponents.Dialog">
        <!-- Personaliza el fondo del diálogo para tener bordes redondeados -->
        <item name="android:windowBackground">@drawable/rounded_square</item>
        <!-- Configuraciones opcionales para el padding del diálogo -->
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

    <!-- Reusable building blocks for form rows and icon buttons -->
    <style name="FormRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/form_row_height</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center|start</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="FormRowText">
        <item name="android:layout_height">@dimen/form_row_inner_height</item>
        <item name="android:gravity">center|start</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColorHint">@color/black</item>
    </style>

    <style name="FormRowIcon">
        <item name="android:layout_height">@dimen/form_row_icon_size</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
    </style>

    <style name="FormRowArrow">
        <item name="android:layout_height">@dimen/form_row_arrow_size</item>
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:src">@drawable/ic_arrow_forward_24</item>
    </style>

    <style name="SegmentedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/segmented_button_height</item>
        <item name="android:layout_weight">2</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:textSize">@dimen/text_small</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:background">@drawable/rounded_square</item>
        <item name="android:elevation">5dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="IconButtonSquare">
        <item name="android:layout_width">@dimen/icon_button_size</item>
        <item name="android:layout_height">@dimen/icon_button_size</item>
        <item name="android:background">@drawable/rounded_square</item>
        <item name="android:elevation">5dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="DialogText">
        <item name="android:textSize">@dimen/text_dialog</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <!-- Toggle rows (popup_notifications, popup_repetition) -->
    <style name="ToggleRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/form_row_height</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center|start</item>
    </style>

    <style name="ToggleRowButton">
        <item name="android:layout_width">@dimen/toggle_button_size</item>
        <item name="android:layout_height">@dimen/toggle_button_size</item>
        <item name="android:layout_marginStart">@dimen/spacing_md</item>
        <item name="android:textOff"></item>
        <item name="android:textOn"></item>
    </style>

    <style name="ToggleRowText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">@dimen/spacing_md</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <!-- Timer configuration popup -->
    <style name="TimerRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="TimerRowLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="StepperButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/rounded_square</item>
        <item name="android:backgroundTint">@color/gris_claro</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="StepperValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@android:drawable/editbox_background</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="StepperToggle">
        <item name="android:layout_width">@dimen/toggle_button_size</item>
        <item name="android:layout_height">@dimen/toggle_button_size</item>
        <item name="android:layout_marginStart">15dp</item>
        <item name="android:layout_marginEnd">5dp</item>
        <item name="android:background">@drawable/radio_button_selector</item>
        <item name="android:button">@android:color/transparent</item>
        <item name="android:textOff"></item>
        <item name="android:textOn"></item>
    </style>

</resources>