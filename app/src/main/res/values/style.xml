<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Personaliza tu tema aquí -->
    </style>
    <style name="fab_3_rounded">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="AppTheme.NoActionBar" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Personaliza tu tema aquí -->
    </style>

    <style name="SplashTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/blue_oval</item>
    </style>

    <!--
   <style name="ThemeChatGPTBlueParent" parent="Theme.MaterialComponents.Light">
       <item name="colorPrimary">@color/c_azul_claro</item>
       <item name="colorSecondary">@color/c_verde_claro</item>
       <item name="colorAccent">@color/c_azul_oscuro</item>
       <item name="colorOnPrimary">@color/c_verde_oscuro</item>
   </style>
