<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================ -->
    <!-- Theme.BBetter — new design-system theme.                       -->
    <!-- Sage primary on sand surface, indigo secondary, coral accent. -->
    <!-- ============================================================ -->
    <style name="Theme.BBetter" parent="Theme.MaterialComponents.Light">
        <item name="colorPrimary">@color/bb_primary</item>
        <item name="colorPrimaryVariant">@color/bb_primary_dark</item>
        <item name="colorOnPrimary">@color/bb_on_primary</item>
        <item name="colorSecondary">@color/bb_secondary</item>
        <item name="colorSecondaryVariant">@color/bb_secondary</item>
        <item name="colorOnSecondary">@color/bb_on_primary</item>
        <item name="colorAccent">@color/bb_accent_energy</item>
        <item name="colorSurface">@color/bb_surface_card</item>
        <item name="colorOnSurface">@color/bb_on_surface</item>
        <item name="colorError">@color/bb_danger</item>

        <item name="android:windowBackground">@color/bb_surface</item>
        <item name="android:colorBackground">@color/bb_surface</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/bb_primary_dark</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@color/bb_surface_card</item>

        <item name="android:textColor">@color/bb_on_surface</item>
        <item name="android:textColorPrimary">@color/bb_on_surface</item>
        <item name="android:textColorSecondary">@color/bb_on_surface_muted</item>
        <item name="android:textColorHint">@color/bb_on_surface_muted</item>
    </style>

    <!-- Base application theme. -->
    <style name="Theme.BBetterCalendar" parent="Theme.BBetter" />

    <style name="ThemeColorBlue" parent="Theme.BBetterCalendar">
        <item name="colorPrimary">@color/azul</item>
        <item name="colorSecondary">@color/gris</item>
        <item name="colorAccent">@color/naranja</item>
        <item name="colorOnPrimary">@color/blanco</item>
    </style>

    <style name="ThemeColorGreen" parent="Theme.BBetterCalendar">
        <item name="colorPrimary">@color/verde</item>
        <item name="colorSecondary">@color/amarillo</item>
        <item name="colorAccent">@color/beige</item>
        <item name="colorOnPrimary">@color/marron_claro</item>
    </style>

    <!-- Legacy alias — kept so existing references keep compiling.
         Now inherits the new BBetter palette so all screens get the
         refreshed look without per-layout edits. -->
    <style name="ThemeChatGPTBlue" parent="Theme.BBetter" />

    <style name="ThemeChatGPTBlue_NoActionBar" parent="Theme.BBetter" />

    <style name="ThemeChatGPTBlue_AndroidPopups" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">@color/bb_primary</item>
        <item name="colorSecondary">@color/bb_secondary</item>
        <item name="colorAccent">@color/bb_accent_energy</item>
        <item name="colorOnPrimary">@color/bb_on_primary</item>
        <item name="android:colorAccent">@color/bb_primary</item>
        <item name="android:buttonTint">@color/bb_primary</item>
    </style>

    <!--Theme.AppCompat.DayNight.NoActionBar-->
    <style name="ThemeColorEvenTalk" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/eventalkAzul</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorSecondary">@color/eventalkAzulSecundario</item>
        <item name="colorAccent">@color/eventalkNaranja</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/black</item>
    </style>

    <style name="ThemeChatGPTBlue.actionBar" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/c_verde_claro</item>
        <item name="colorSecondary">@color/c_azul_claro</item>
        <item name="colorAccent">@color/c_azul_oscuro</item>
        <item name="colorOnPrimary">@color/c_verde_oscuro</item>
    </style>

    <style name="ThemeColorNavyBlue" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/azul_marino</item>
        <item name="colorSecondary">@color/teal</item>
        <item name="colorAccent">@color/plata</item>
        <item name="colorOnPrimary">@color/blanco</item>
    </style>

    <style name="ThemeColorPurple" parent="Theme.BBetterCalendar">
        <item name="colorPrimary">@color/purpura</item>
        <item name="colorSecondary">@color/gris_oscuro</item>
        <item name="colorAccent">@color/magenta</item>
        <item name="colorOnPrimary">@color/blanco</item>
    </style>



    <style name="FakeTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

</resources>